{
  "name": "weixin-claw-bot-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building Weixin bots on top of the iLink bot HTTP API",
  "license": "MIT",
  "author": "wikig",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "weixin",
    "wechat",
    "bot",
    "sdk",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
